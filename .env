FLASK_RUN_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Listener mode — choose HTTP, HTTPS, or both
# ---------------------------------------------------------------------------

# Enable HTTP listener (default: true)
ENABLE_HTTP=true

# Enable HTTPS listener (default: false)
ENABLE_HTTPS=false

# HTTP listen port (default: 8080)
HTTP_PORT=8080

# HTTPS listen port (default: 8443)
# HTTPS_PORT=8443

# ---------------------------------------------------------------------------
# SSL / TLS — required when ENABLE_HTTPS=true
# ---------------------------------------------------------------------------
# SSL_CERT_PATH=certificates/cert.pem
# SSL_KEY_PATH=certificates/key.pem
#
# Generate a self-signed cert:
#   mkdir -p certificates
#   openssl req -x509 -newkey rsa:4096 -nodes \
#     -out certificates/cert.pem -keyout certificates/key.pem -days 365

# ---------------------------------------------------------------------------
# Legacy variables (still supported for backward compatibility)
# USE_HTTPS=true  is equivalent to ENABLE_HTTPS=true + ENABLE_HTTP=false
# FLASK_RUN_PORT  is an alias for HTTP_PORT
# ---------------------------------------------------------------------------
# USE_HTTPS=false
# FLASK_RUN_PORT=8080

# ---------------------------------------------------------------------------
# Other options
# ---------------------------------------------------------------------------
# FLASK_DEBUG=false
# DISABLE_TOOLS_COLUMN=false
